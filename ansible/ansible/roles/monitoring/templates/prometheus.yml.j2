global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets: ["localhost:9090"]

  - job_name: flask-nodes
    static_configs:
      - targets:
{% for host in groups['flask'] %}
          - "{{ hostvars[host]['ansible_host'] | default(host) }}:9100"
{% endfor %}

  - job_name: nginx
    static_configs:
      - targets:
{% for host in groups['nginx'] %}
          - "{{ hostvars[host]['ansible_host'] | default(host) }}:9100"
{% endfor %}
